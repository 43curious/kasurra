---

---

<section class="add-section" aria-labelledby="add-title">
    <div class="parsed-preview visible" id="parsed-preview">
        <h3 id="add-title">
            Add expenses <span class="badge">Manual Entry</span>
        </h3>

        <div class="parsed-grid">
            <div class="parsed-field" style="grid-column: span 2">
                <label for="p-name">Description</label>
                <input
                    type="text"
                    id="p-name"
                    placeholder="What did you spend on?"
                />
            </div>
            <div class="parsed-field">
                <label for="p-amount">Amount (€)</label>
                <input
                    type="number"
                    id="p-amount"
                    placeholder="0.00"
                    step="0.01"
                    min="0"
                />
            </div>
            <div class="parsed-field">
                <label for="p-date">Date</label>
                <input type="date" id="p-date" />
            </div>
            <div class="parsed-field">
                <label for="p-category">Category</label>
                <select id="p-category">
                    <option value="food">🍕 Food &amp; Drink</option>
                    <option value="transport">🚇 Transport</option>
                    <option value="shopping">🛍️ Shopping</option>
                    <option value="entertainment">🎬 Entertainment</option>
                    <option value="health">💊 Health</option>
                    <option value="home">🏠 Home</option>
                    <option value="other" selected>📦 Other</option>
                </select>
            </div>
        </div>
        <div class="confirm-row">
            <button class="btn-confirm" id="btn-confirm">✓ Add Record</button>
            <button class="btn-discard" id="btn-discard">Clear</button>
        </div>
    </div>
</section>
