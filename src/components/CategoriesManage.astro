---
---
<div class="panel-view active">
    <div class="categories-explorer">
        <div class="categories-section">
            <h3>Expense Categories</h3>
            <div class="categories-grid" id="expense-cats-grid">
                <!-- Categories will be rendered here -->
            </div>
            <button class="add-cat-btn" data-type="expense">+ Add Expense Category</button>
        </div>

        <div class="categories-section">
            <h3>Income Categories</h3>
            <div class="categories-grid" id="income-cats-grid">
                <!-- Categories will be rendered here -->
            </div>
            <button class="add-cat-btn" data-type="income">+ Add Income Category</button>
        </div>
    </div>

    <!-- Add/Edit Category Modal -->
    <div id="cat-modal" class="modal" style="display: none;">
        <div class="modal-content">
            <h3 id="modal-title">Add Category</h3>
            <input type="hidden" id="cat-edit-id">
            <input type="hidden" id="cat-edit-type">
            <div class="form-group">
                <label>Name</label>
                <input type="text" id="cat-name" placeholder="e.g. Hobbies">
            </div>
            <div class="form-group">
                <label>Emoji</label>
                <input type="text" id="cat-emoji" placeholder="e.g. 🎨">
            </div>
            <div class="form-group">
                <label>Color</label>
                <input type="color" id="cat-color" value="#3b82f6">
            </div>
            <div class="modal-actions">
                <button id="btn-delete-cat" class="btn-discard" style="display: none;">Delete</button>
                <button id="btn-save-cat" class="btn-confirm">Save</button>
                <button id="btn-cancel-cat" class="btn-discard">Cancel</button>
            </div>
        </div>
    </div>
</div>

<style is:global>
    .categories-explorer {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    .categories-section {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 18px;
        box-shadow: var(--shadow);
    }
    .categories-section h3 {
        margin-bottom: 14px;
        font-family: 'Playfair Display', serif;
        font-size: 22px;
    }
    .categories-grid {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 14px;
    }
    .cat-manage-item {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: none;
        min-height: 54px;
        transition: transform 0.2s, border-color 0.2s;
    }
    .cat-manage-item:hover {
        border-color: var(--accent-hover);
    }
    .cat-manage-item.dragging {
        opacity: 0.55;
        border-style: dashed;
        background: var(--surface2);
    }
    .drag-handle {
        border: 1px solid var(--border);
        background: #f8fafc;
        color: #94a3b8;
        font-size: 14px;
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        cursor: grab;
        margin-left: 4px;
        transition: all 0.2s;
        flex-shrink: 0;
    }
    .drag-handle:hover {
        background: #f1f5f9;
        border-color: #dbe3ec;
        color: #7b8794;
    }
    .cat-manage-item .cat-icon {
        width: 38px;
        height: 38px;
        font-size: 18px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .edit-cat-btn {
        border: 1px solid var(--border);
        background: var(--surface2);
        color: var(--muted);
        min-width: 56px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        cursor: pointer;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.4px;
        transition: all 0.2s;
    }
    .edit-cat-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-soft);
    }
    .cat-manage-labels {
        flex: 1;
        min-width: 0;
    }
    .cat-manage-name {
        font-weight: 600;
    }
    .cat-manage-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 6px;
        flex-wrap: wrap;
    }
    .cat-manage-meta {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }
    .add-cat-btn {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--border);
        background: var(--surface2);
        border-radius: var(--radius-sm);
        color: var(--muted);
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }
    .add-cat-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-soft);
    }
    
    /* Simple Modal Styles */
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(4px);
    }
    .modal-content {
        background: var(--surface);
        padding: 32px;
        border-radius: var(--radius);
        width: 400px;
        box-shadow: var(--shadow-lg);
    }
    .form-group {
        margin-bottom: 16px;
    }
    .form-group label {
        display: block;
        font-size: 12px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }
    .form-group input {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--surface2);
    }
    .modal-actions {
        display: flex;
        gap: 12px;
        margin-top: 24px;
        flex-wrap: wrap;
    }
    .modal-actions button {
        flex: 1 1 0;
    }
    @media (max-width: 900px) {
        .categories-explorer {
            grid-template-columns: 1fr;
        }
    }
</style>
