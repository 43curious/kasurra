---
import AppLayout from "../../layouts/AppLayout.astro";
import { requireAdmin } from "../../lib/server-auth";

const { user, response } = await requireAdmin(Astro.cookies);
if (response) return Astro.redirect('/dashboard');
---

<AppLayout 
    title="Admin Dashboard — Zeken" 
    pageTitle="Admin Console" 
    pageSubtitle="Manage application users and system configuration."
    suppressStats={true}
>
    <div class="admin-page">
        <section class="admin-actions">
            <button class="btn-confirm" id="btn-new-user">
                <span>+</span> New User
            </button>
        </section>

        <section class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="user-table-body">
                    <!-- Loaded via client script -->
                    <tr><td colspan="5" style="text-align:center; padding: 40px;">Loading users...</td></tr>
                </tbody>
            </table>
        </section>
    </div>

    <!-- New User Modal -->
    <div id="modal-new-user" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Create New User</h3>
                <button class="modal-close" id="modal-close">×</button>
            </div>
            <form id="form-new-user" class="admin-form">
                <label>
                    <span>Full Name</span>
                    <input type="text" name="name" required placeholder="John Doe" />
                </label>
                <label>
                    <span>Email Address</span>
                    <input type="email" name="email" required placeholder="john@example.com" />
                </label>
                <label>
                    <span>Password</span>
                    <input type="password" name="password" required />
                </label>
                <label>
                    <span>Role</span>
                    <select name="role">
                        <option value="user">User</option>
                        <option value="admin">Admin</option>
                    </select>
                </label>
                <div class="modal-actions">
                    <button type="button" class="btn-discard" id="btn-cancel">Cancel</button>
                    <button type="submit" class="btn-confirm">Create User</button>
                </div>
            </form>
        </div>
    </div>
</AppLayout>

<style is:global>
    .admin-page {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }
    .admin-actions {
        display: flex;
        justify-content: flex-end;
    }
    .admin-table-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }
    .admin-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }
    .admin-table th {
        background: var(--surface2);
        padding: 16px 20px;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        border-bottom: 1px solid var(--border);
    }
    .admin-table td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
    }
    .admin-table tr:last-child td {
        border-bottom: none;
    }
    .role-badge {
        display: inline-flex;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        background: var(--surface2);
    }
    .role-badge--admin {
        background: var(--accent-soft);
        color: var(--accent);
    }
    .admin-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .admin-form label {
        display: flex;
        flex-direction: column;
        gap: 8px;
        font-size: 13px;
        font-weight: 600;
    }
    .admin-form input, .admin-form select {
        padding: 12px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--surface2);
        color: var(--text);
    }
    
    .modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(4px);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }
    .modal.active {
        display: flex;
    }
    .modal-content {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        width: 100%;
        max-width: 450px;
        padding: 32px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }
    .modal-header h3 {
        margin: 0;
        font-family: 'Playfair Display', serif;
        font-size: 24px;
    }
    .modal-close {
        background: none;
        border: none;
        color: var(--muted);
        font-size: 24px;
        cursor: pointer;
    }
    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 12px;
    }
</style>

<script>
    import { UI } from "../../lib/ui-utils";

    const tableBody = document.getElementById('user-table-body');
    const modal = document.getElementById('modal-new-user');
    const btnNew = document.getElementById('btn-new-user');
    const btnCancel = document.getElementById('btn-cancel');
    const modalClose = document.getElementById('modal-close');
    const form = document.getElementById('form-new-user') as HTMLFormElement;

    async function loadUsers() {
        try {
            const res = await fetch('/api/admin/users');
            const users = await res.json();
            
            if (tableBody) {
                tableBody.innerHTML = users.map((u: any) => `
                    <tr>
                        <td style="font-weight: 600;">${u.name}</td>
                        <td style="color: var(--muted);">${u.email}</td>
                        <td><span class="role-badge ${u.role === 'admin' ? 'role-badge--admin' : ''}">${u.role}</span></td>
                        <td style="color: var(--muted); font-size: 12px;">${new Date(u.created).toLocaleDateString()}</td>
                        <td>
                            <button class="btn-discard btn-sm" onclick="deleteUser('${u.id}')">Delete</button>
                        </td>
                    </tr>
                `).join('');
            }
        } catch (e) {
            UI.showToast('Could not load users');
        }
    }

    // @ts-ignore
    window.deleteUser = async (id: string) => {
        if (!confirm('Are you sure you want to delete this user? All their data will be purged.')) return;
        
        try {
            const res = await fetch('/api/admin/users', {
                method: 'DELETE',
                body: JSON.stringify({ id })
            });
            if (res.ok) {
                UI.showToast('User deleted');
                loadUsers();
            } else {
                const data = await res.json();
                UI.showToast(data.error || 'Delete failed');
            }
        } catch (e) {
            UI.showToast('Error deleting user');
        }
    };

    btnNew?.addEventListener('click', () => modal?.classList.add('active'));
    [btnCancel, modalClose].forEach(btn => btn?.addEventListener('click', () => modal?.classList.remove('active')));

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const payload = Object.fromEntries(formData);
        
        try {
            const res = await fetch('/api/admin/users', {
                method: 'POST',
                body: JSON.stringify(payload)
            });
            
            if (res.ok) {
                UI.showToast('User created');
                modal?.classList.remove('active');
                form.reset();
                loadUsers();
            } else {
                const data = await res.json();
                UI.showToast(data.error || 'Create failed');
            }
        } catch (e) {
            UI.showToast('Error creating user');
        }
    });

    loadUsers();
</script>
